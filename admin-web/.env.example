# Copiá este archivo a .env.local y completá con los valores del proyecto.
# Son los mismos URL + anon key que usa mobile (ambos son públicos — no son secretos).
# El service_role key NO va acá: sólo debe vivir en el backend (Edge Functions).

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
